    {
      "rank": 1,
      "name": "Dialyn",
      "priority": "Highest impact",
      "why": "Best single account upgrade because she directly improves Ye Shunguang and Yixuan, two of her strongest foundations. She adds Stun DMG multiplier, longer stun windows, and Ultimate conversion for burst-heavy teams.",
      "team": "Primary teams: Ye Shunguang + Dialyn + Sunna/Zhao; Yixuan + Dialyn + Lucia. Also flexible as a premium stun slot."
    },
    {
      "rank": 2,
      "name": "Sunna",
      "priority": "Very high",
      "why": "Completes the premium Ye Shunguang shell and keeps Astra/Yuzuha free for other teams. Since she already owns Ye and Zhao, Sunna turns Physical coverage into a much cleaner top-end team.",
      "team": "Primary team: Ye Shunguang + Dialyn/Zhao/Ju Fufu + Sunna. Secondary value: general Attack support."
    },
    {
      "rank": 3,
      "name": "Seed",
      "priority": "Very high",
      "why": "Best partner for Cissia and the cleanest way to turn her Electric roster into a real second carry lane. This also improves missing Electric coverage quality beyond solo Cissia/Yanagi setups.",
      "team": "Primary team: Seed + Cissia + Astra/Sunna/Nicole. Helps Electric coverage."
    },
    {
      "rank": 4,
      "name": "Burnice",
